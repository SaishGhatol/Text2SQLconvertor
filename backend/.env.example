ENVIRONMENT=development
SECRET_KEY=replace-with-a-strong-secret-key-at-least-32-characters
ENCRYPTION_KEY=
DATABASE_URL=sqlite+aiosqlite:///./smartquery.db
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3

QUERY_CACHE_TTL=300
MAX_QUERY_RETRIES=3
MAX_HISTORY_PER_USER=100
QUERY_MAX_TEXT_LENGTH=500
MAX_CONNECTION_PROFILES_PER_USER=10

AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
QUERY_RATE_LIMIT_PER_MINUTE=30
